<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #2b2d42;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="sn.messagerie.app_messagerie.client.fx.ChatController">


    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #1a1b2e; -fx-padding: 10 15;">
            <Label fx:id="userInfoLabel" text="👤 Utilisateur"
                   style="-fx-text-fill: #edf2f4; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusDot" text="🟢"/>
            <Button text="Nouvelle conv." onAction="#handleNewConversation"
                    style="-fx-background-color: #06d6a0; -fx-text-fill: white;
                           -fx-font-size: 11px; -fx-cursor: hand;"/>
            <Button text="Déconnexion" onAction="#handleLogout"
                    style="-fx-background-color: #ef233c; -fx-text-fill: white;
                           -fx-font-size: 11px; -fx-cursor: hand;"/>
        </HBox>
    </top>


    <center>
        <SplitPane dividerPositions="0.3">

            <VBox style="-fx-background-color: #1a1b2e;" minWidth="200">


                <HBox style="-fx-padding: 10 10 6 10;" spacing="6" alignment="CENTER">
                    <TextField fx:id="searchField"
                               promptText="🔍  Rechercher..."
                               HBox.hgrow="ALWAYS"
                               onKeyReleased="#handleSearch"
                               style="-fx-background-color: #2b2d42; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #8d99ae; -fx-background-radius: 20;
                                      -fx-padding: 6 12; -fx-font-size: 12px;"/>
                </HBox>

                <Separator style="-fx-background-color: #2b2d42;"/>


                <Label text="  MESSAGES"
                       style="-fx-text-fill: #8d99ae; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 8 10 4 10;"/>


                <ListView fx:id="conversationsListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;
                                 -fx-border-color: transparent;
                                 -fx-padding: 0;"/>

                <Separator style="-fx-background-color: #2b2d42;"/>


                <Label text="  MEMBRES EN LIGNE"
                       style="-fx-text-fill: #8d99ae; -fx-font-size: 10px;
                              -fx-font-weight: bold; -fx-padding: 8 10 4 10;"/>


                <ListView fx:id="onlineMembersListView"
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;
                                 -fx-border-color: transparent;
                                 -fx-padding: 0;"/>

            </VBox>


            <VBox VBox.vgrow="ALWAYS">


                <HBox fx:id="conversationHeader"
                      style="-fx-background-color: #3a3d58; -fx-padding: 10 15;"
                      alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="contactAvatarLabel" text="👤"
                           style="-fx-font-size: 20px;"/>
                    <VBox spacing="1">
                        <Label fx:id="conversationLabel"
                               text="Sélectionnez une conversation"
                               style="-fx-text-fill: #edf2f4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label fx:id="contactStatusLabel" text=""
                               style="-fx-text-fill: #06d6a0; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>


                <ScrollPane fx:id="messagesScrollPane" VBox.vgrow="ALWAYS"
                            fitToWidth="true"
                            style="-fx-background-color: #2b2d42; -fx-border-color: transparent;">
                    <VBox fx:id="messagesContainer" spacing="6"
                          style="-fx-padding: 15; -fx-background-color: #2b2d42;"/>
                </ScrollPane>


                <HBox spacing="8" style="-fx-padding: 10; -fx-background-color: #1a1b2e;"
                      alignment="CENTER">
                    <TextField fx:id="messageField"
                               promptText="Écrivez votre message... (Entrée pour envoyer)"
                               HBox.hgrow="ALWAYS"
                               onAction="#handleSendMessage"
                               style="-fx-background-color: #3a3d58; -fx-text-fill: white;
                                      -fx-prompt-text-fill: #8d99ae; -fx-padding: 10 14;
                                      -fx-background-radius: 20; -fx-font-size: 13px;"/>
                    <Button text="➤" onAction="#handleSendMessage"
                            style="-fx-background-color: #ef233c; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-cursor: hand;
                                   -fx-background-radius: 50; -fx-min-width: 38;
                                   -fx-min-height: 38; -fx-font-size: 14px;"/>
                </HBox>

            </VBox>

        </SplitPane>
    </center>

    <bottom>
        <Label fx:id="bottomStatusLabel" text=""
               maxWidth="Infinity"
               style="-fx-background-color: #1a1b2e; -fx-text-fill: #8d99ae;
                      -fx-font-size: 10px; -fx-padding: 4 15;"/>
    </bottom>

</BorderPane>
